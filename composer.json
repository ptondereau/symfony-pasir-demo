{
    "name": "pasir/symfony-demo",
    "description": "Symfony demo app running on Pasir PHP server",
    "type": "project",
    "require": {
        "php": "^8.1",
        "symfony/http-foundation": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
